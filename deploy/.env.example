# Copy to .env and fill in values before deploying.

# GHCR image prefix (lowercase): ghcr.io/<github-owner>/<repo-name>
GHCR_IMAGE_PREFIX=ghcr.io/your-username/hng14-stage9-job-scheduler
IMAGE_TAG=latest

# Public domain (dynamic DNS, e.g. myscheduler.duckdns.org)
DOMAIN=scheduler.example.com
CERTBOT_EMAIL=you@example.com

# Optional
SCHEDULER_ALGORITHM=heap
DLQ_ALERT_THRESHOLD=5
DLQ_ALERT_EMAIL=ops@dilamme.com
HTTP_PORT=80
HTTPS_PORT=443

# Staging: set to 1 for Let's Encrypt staging (avoid rate limits while testing)
# CERTBOT_STAGING=1
